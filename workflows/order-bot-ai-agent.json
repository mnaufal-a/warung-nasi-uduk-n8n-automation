    {
      "parameters": {
        "jsCode": "const output = $('AI Agent').item.json.output;\n\n// Cek apakah ada blok ORDER\nif (!output.includes('###ORDER###')) {\n  return [{ json: { hasOrder: false } }];\n}\n\n// Ekstrak blok ORDER\nconst orderBlock = output.split('###ORDER###')[1].split('###END###')[0];\nconst lines = orderBlock.trim().split('\\n');\n\n// Parse data dari blok ORDER\nconst data = {};\nfor (const line of lines) {\n  const [key, ...rest] = line.split(':');\n  if (key && rest.length) {\n    data[key.trim()] = rest.join(':').trim();\n  }\n}\n\n// Hitung jumlah item dari field PESANAN\nconst pesananText = data['PESANAN'] || '';\nlet jumlahItem = 0;\nconst itemMatches = pesananText.match(/x\\s*(\\d+)/gi);\nif (itemMatches) {\n  itemMatches.forEach(match => {\n    jumlahItem += parseInt(match.replace(/x\\s*/i, ''));\n  });\n}\n\nreturn [{\n  json: {\n    hasOrder: true,\n    nama: data['NAMA'] || '',\n    tipe: data['TIPE'] || '',\n    alamat: data['ALAMAT'] || '',\n    pesanan: data['PESANAN'] || '',\n    total: data['TOTAL'] || '',\n    jumlahItem: jumlahItem,\n    nomorWA: $('Webhook').item.json.body.sender,\n  }\n}];"
      },
