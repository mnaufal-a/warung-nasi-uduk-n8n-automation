    {
      "parameters": {
        "jsCode": "// Ambil pesan dari semua items yang masuk (dari Google Sheets Menu)\n// Data webhook diambil dari node Webhook langsung\nconst pesanCustomer = $('Webhook').item.json.body.pesan || '';\n\n// Data menu dari input (semua baris sheet Menu)\nconst dataMenu = items;\n\n// Ekstrak nama menu dan jumlah dari pesan\nconst pesanLower = pesanCustomer.toLowerCase();\n\nconst bagianPesan = pesanLower.split(/\\s*(dan|,|\\+|sama|terus|juga)\\s*/i)\n  .filter(b => b.trim().length > 2); // buang kata pemisah & string pendek\n\nconst hasilOrder = [];\n\nfor (const bagian of bagianPesan) {\n  \n  // Cari menu yang cocok\n  for (const menuRow of dataMenu) {\n    const namaMenu = (menuRow.json['Nama Menu'] || '').toLowerCase();\n    \n    if (bagian.includes(namaMenu)) {\n      const angkaBagian = bagian.match(/\\d+/g);\n      const jumlah = angkaBagian ? parseInt(angkaBagian[0]) : 1;\n      const harga = parseInt(menuRow.json['Harga']) || 0;\n\n      hasilOrder.push({\n        nama: menuRow.json['Nama Menu'],\n        jumlah: jumlah,\n        hargaSatuan: harga,\n        subTotal: harga * jumlah,\n      })\n      break;\n    }\n  }\n}\n\n//buat hitung total order\nconst totalItem = hasilOrder.reduce((sum, item) => sum + item.jumlah, 0 );\nconst totalHarga = hasilOrder.reduce((sum, item) => sum + item.subTotal, 0);\n\n//ini format detailpesenan\nconst detailMenu = hasilOrder.map(item => \n  `${item.nama} x${item.jumlah} = Rp ${item.subTotal.toLocaleString('id-ID')}`  \n).join(', ');\n\nconst formatRupiah = (n) => 'Rp ' + n.toLocaleString('id-ID');\n\nreturn [{\n  json: {\n    namaMenu: hasilOrder.map(i => i.nama).join(' + '),\n    jumlahPesan: totalItem,\n    totalHarga,\n    totalHargaFormatted: formatRupiah(totalHarga),\n    detailMenu,\n    pesanAsli: pesanCustomer,\n    namaCust: $('Webhook').item.json.body.name,\n    nomorCust: $('Webhook').item.json.body.sender\n  },\n  pairedItem: { item: 0 }\n}];"
      },
